DATABASE_URL="mysql://musionuser:musionpassword@localhost:3306/musiondb"
JWT_SECRET="troque-este-segredo"

# Login com Google nativo:
# Crie um OAuth Client ID do tipo Web Application e coloque aqui.
# O Android OAuth Client ID precisa existir no Google Cloud com package + SHA-1,
# mas o idToken enviado pelo app usa o Web Client ID como audience.
GOOGLE_WEB_CLIENT_ID=""
# Opcional: lista separada por virgula caso voce prefira aceitar varios audiences.
GOOGLE_CLIENT_IDS=""

SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
LASTFM_API_KEY=""

# Musion Lens:
# - "smart-free" usa OCR local com pre-processamento e Gemini como fallback, sem Google Cloud/billing.
# - "gemini" usa somente Gemini Vision.
# - "ocr" usa somente OCR local gratuito.
MUSION_LENS_PROVIDER="smart-free"
MUSION_LENS_DAILY_LIMIT="20"
MUSION_LENS_OCR_LANGS="eng+por"

# Gemini Vision. Use quando MUSION_LENS_PROVIDER="gemini" ou como fallback do modo smart-free.
GEMINI_API_KEY=""
GEMINI_VISION_MODEL="gemini-2.5-flash"

# OpenAI Vision opcional. Hoje fica como provider legado/fallback se voce escolher MUSION_LENS_PROVIDER="openai".
OPENAI_API_KEY=""
OPENAI_VISION_MODEL="gpt-4o-mini"

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

MODERATION_ADMIN_USER_IDS=""

# Redefinicao de senha por email:
# SMTP_HOST: servidor SMTP. Exemplos: smtp.gmail.com, smtp.sendgrid.net, smtp.mailgun.org.
# SMTP_PORT: 587 para TLS por STARTTLS; 465 quando SMTP_SECURE="true".
# SMTP_SECURE: "false" para porta 587, "true" para porta 465.
# SMTP_USER: usuario/login do provedor SMTP.
# SMTP_PASS: senha/app password/token SMTP. Nunca suba esse valor para o GitHub.
# SMTP_FROM: remetente exibido no email.
# Observacao: contas Outlook/Hotmail pessoais novas podem bloquear SMTP AUTH com erro 535 5.7.139.
# Se isso acontecer, use Gmail com senha de app ou um provedor SMTP transacional.
# Exemplo Gmail:
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="seuemail@gmail.com"
# SMTP_PASS="senha-de-app-do-gmail"
# SMTP_FROM="Musion <seuemail@gmail.com>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Musion <no-reply@musion.app>"
